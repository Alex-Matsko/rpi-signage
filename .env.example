# Скопируйте в .env и задайте свои значения:  cp .env.example .env

# Пароль администратора при первом запуске (обязательно)
ADMIN_PASSWORD=смените-меня

# ВАЖНО: абсолютный путь к данным — чтобы они не терялись при
# переносе/переклонировании проекта. Папка переживает обновления.
SIGNAGE_DATA_PATH=/opt/rpi-signage/data

# Внешний порт веб-интерфейса
SIGNAGE_PORT=8080

# Часовой пояс сервера (должен совпадать с устройствами)
TZ=Europe/Moscow

# Лимит размера загружаемого файла, МБ
SIGNAGE_MAX_UPLOAD_MB=1024
